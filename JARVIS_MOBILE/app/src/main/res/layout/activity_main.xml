<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#06101a"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#091520"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <View android:id="@+id/status_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/circle_green"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="J.A.R.V.I.S  V3"
            android:textColor="#00d4ff"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ULTIMATE"
            android:textColor="#005577"
            android:textSize="10sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Log area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#040d18"
        android:padding="12dp">

        <TextView
            android:id="@+id/log_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Initializing JARVIS..."
            android:textColor="#88bbdd"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:lineSpacingMultiplier="1.5"/>
    </ScrollView>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#091520"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/input_box"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:hint="Type any command..."
            android:hintTextColor="#334455"
            android:textColor="#c0e0ff"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:background="@drawable/input_bg"
            android:paddingHorizontal="12dp"
            android:imeOptions="actionSend"
            android:inputType="text"
            android:maxLines="1"/>

        <ImageButton
            android:id="@+id/mic_btn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/btn_bg_blue"
            android:src="@android:drawable/ic_btn_speak_now"
            android:layout_marginStart="6dp"
            android:contentDescription="Voice"/>

        <Button
            android:id="@+id/send_btn"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="SEND"
            android:textColor="#00d4ff"
            android:background="@drawable/btn_bg_outline"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginStart="6dp"
            android:paddingHorizontal="12dp"/>
    </LinearLayout>
</LinearLayout>
